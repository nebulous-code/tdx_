# Copy to backend/.env and fill in. backend/.env is gitignored.
# Generate the VAPID keypair with:  npm run gen-vapid

PORT=3000
HOST=0.0.0.0
# Set TZ to your local timezone so reminder timestamps (naive local datetimes)
# are compared correctly by the scheduler.
TZ=America/New_York
# Where the SQLite file lives. In Docker this is overridden to /data/tdx.db.
DB_PATH=../data/tdx.db

# Web Push (VAPID). Subject is a mailto: or https: contact URL.
VAPID_SUBJECT=mailto:you@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
