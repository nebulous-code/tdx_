# Copy to backend/.env and adjust. backend/.env is gitignored.

PORT=3000
HOST=0.0.0.0
# Set TZ to your local timezone so created/completed date stamps are local.
TZ=America/New_York
# Where the SQLite file lives. In Docker this is overridden to /data/tdx.db.
DB_PATH=../data/tdx.db

# Secret used to sign session cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Must stay stable across restarts; rotating it logs everyone out. Required.
# In Docker this is supplied via compose (repo-root .env -> ${SESSION_SECRET}).
SESSION_SECRET=replace-me-with-a-long-random-string
